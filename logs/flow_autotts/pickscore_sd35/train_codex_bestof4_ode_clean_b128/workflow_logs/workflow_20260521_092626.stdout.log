lf._next_pid; self._next_pid += 1\n            self._particles[pid] = DummyParticle(id=pid, time=float(target_time), status='active' if target_time < 1.0 else 'completed', last_preview_id=None)\n            child_ids.append(pid)\n        return child_ids\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            self._particles[pid].status='pruned'\n    def answer(self, rule='best_preview_score'):\n        return SimpleNamespace(rule=rule, nfe_used=self.budget-self.budget_left)\n    def get_state(self):\n        return DummyState(\n            particles={pid: p for pid,p in self._particles.items()},\n            previews={aid: p for aid,p in self._previews.items()},\n            budget_left=self.budget_left,\n        )\n\nctrl = OptimalController()\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = DummyEnv()\n    ans = ctrl.solve(env, beta)\n    print(beta, ans.rule, ans.nfe_used, env.budget_left)\nPY\"","aggregated_output":"0.0 latest_active 10 54\n0.25 best_preview_score 27 37\n0.5 best_preview_score 32 32\n0.75 best_preview_score 48 16\n1.0 best_preview_score 65 -1\n","exit_code":0,"status":"completed"}}
