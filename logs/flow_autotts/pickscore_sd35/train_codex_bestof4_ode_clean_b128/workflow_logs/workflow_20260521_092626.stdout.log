{"type":"item.started","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"python - <<'PY'\nfrom types import SimpleNamespace\nfrom flow_autotts.controllers.optimal import OptimalController\nfrom flow_autotts.core.state import ParticleSummary, PreviewRecord\n\nclass FakeEnv:\n    def __init__(self):\n        self.time_grid = [0.0, 0.2, 0.5, 0.8, 1.0]\n        self.budget = 50\n        self.budget_left = 50\n        self._next_pid = 0\n        self._next_aid = 0\n        self._particles = {}\n        self._previews = {}\n    def spawn(self, n):\n        ids = []\n        for _ in range(n):\n            pid = self._next_pid; self._next_pid += 1\n            self._particles[pid] = ParticleSummary(pid, 0.0, None, None, 0, 'active', None, 0)\n            ids.append(pid)\n        return ids\n    def forward(self, particle_id, target_time, solver='euler', cfg=None):\n        self.budget_left -= 1\n        p = self._particles[particle_id]\n        self._particles[particle_id] = ParticleSummary(p.id, target_time, p.parent_id, p.source_anchor_id, p.nfe_used+1, 'completed' if target_time >= 1.0 else 'active', p.last_preview_id, p.num_children)\n        return self._particles[particle_id]\n    def preview(self, particle_id, mode='clean_anchor', scorer='default'):\n        self.budget_left -= 1\n        p = self._particles[particle_id]\n        aid = self._next_aid; self._next_aid += 1\n        score = 0.5 + 0.01 * particle_id + 0.02 * p.time\n        prev = PreviewRecord(aid, particle_id, p.time, score, {'pickscore': score}, uncertainty=max(0.0, 1.0 - p.time), drift=0.0)\n        self._previews[aid] = prev\n        self._particles[particle_id] = ParticleSummary(p.id, p.time, p.parent_id, p.source_anchor_id, p.nfe_used+1, p.status, aid, p.num_children)\n        return prev\n    def backward(self, anchor_id, target_time, noise_policy='fresh_noise', num_children=1, mask=None, strength=1.0):\n        self.budget_left -= 0\n        ids = []\n        for _ in range(num_children):\n            pid = self._next_pid; self._next_pid += 1\n            self._particles[pid] = ParticleSummary(pid, target_time, self._previews[anchor_id].particle_id, anchor_id, 0, 'active' if target_time < 1.0 else 'completed', None, 0)\n            ids.append(pid)\n        return ids\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            p = self._particles[pid]\n            self._particles[pid] = ParticleSummary(p.id, p.time, p.parent_id, p.source_anchor_id, p.nfe_used, 'pruned', p.last_preview_id, p.num_children)\n    def answer(self, rule='best_preview_score'):\n        return SimpleNamespace(rule=rule, nfe_used=self.budget - self.budget_left)\n    def get_state(self):\n        return SimpleNamespace(particles=self._particles, previews=self._previews)\n\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = FakeEnv()\n    out = OptimalController().solve(env, beta)\n    print(beta, out.rule, out.nfe_used, len(env._previews), len(env._particles))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
