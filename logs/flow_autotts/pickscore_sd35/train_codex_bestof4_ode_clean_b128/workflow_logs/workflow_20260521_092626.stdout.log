{"type":"item.started","item":{"id":"item_30","type":"command_execution","command":"/bin/bash -lc \"python3 - <<'PY'\nfrom dataclasses import dataclass\n\nfrom flow_autotts.controllers.optimal import OptimalController\nfrom flow_autotts.core.errors import BudgetExceededError, InvalidActionError\nfrom flow_autotts.core.state import AnswerRecord, ControllerState, ParticleSummary, PreviewRecord\n\n\n@dataclass\nclass P:\n    id: int\n    time: float\n    parent_id: int | None = None\n    source_anchor_id: int | None = None\n    nfe_used: int = 0\n    status: str = \\\"active\\\"\n    last_preview_id: int | None = None\n    num_children: int = 0\n\n\nclass FakeEnv:\n    def __init__(self, budget=128):\n        self.time_grid = tuple(i / 10 for i in range(11))\n        self.budget = budget\n        self._budget_left = budget\n        self._particles = {}\n        self._previews = {}\n        self._next_pid = 0\n        self._next_aid = 0\n\n    @property\n    def budget_left(self):\n        return self._budget_left\n\n    def spawn(self, n):\n        ids = []\n        for _ in range(n):\n            pid = self._next_pid\n            self._next_pid += 1\n            self._particles[pid] = P(id=pid, time=0.0)\n            ids.append(pid)\n        return ids\n\n    def forward(self, particle_id, target_time, solver=\\\"euler\\\", cfg=None):\n        if self._budget_left < 1:\n            raise BudgetExceededError()\n        p = self._particles[particle_id]\n        if p.status == \\\"pruned\\\" or target_time < p.time:\n            raise InvalidActionError()\n        self._budget_left -= 1\n        p.time = float(target_time)\n        p.nfe_used += 1\n        if p.time >= 1.0:\n            p.status = \\\"completed\\\"\n        return self.get_state().particles[particle_id]\n\n    def preview(self, particle_id, mode=\\\"clean_anchor\\\", scorer=\\\"default\\\"):\n        if self._budget_left < 1:\n            raise BudgetExceededError()\n        p = self._particles[particle_id]\n        if p.status == \\\"pruned\\\":\n            raise InvalidActionError()\n        self._budget_left -= 1\n        aid = self._next_aid\n        self._next_aid += 1\n        score = 0.70 + 0.06 * p.time - 0.01 * (particle_id % 3)\n        if p.parent_id is not None:\n            score += 0.005\n        preview = PreviewRecord(\n            id=aid,\n            particle_id=particle_id,\n            time=p.time,\n            score=score,\n            score_dict={\\\"pickscore\\\": score},\n            uncertainty=max(0.0, 0.25 - 0.15 * p.time),\n            drift=None,\n            embedding_ref=None,\n        )\n        self._previews[aid] = preview\n        p.last_preview_id = aid\n        p.nfe_used += 1\n        return preview\n\n    def backward(self, anchor_id, target_time, noise_policy=\\\"fresh_noise\\\", num_children=1, mask=None, strength=1.0):\n        if mask is not None or anchor_id not in self._previews:\n            raise InvalidActionError()\n        anchor = self._previews[anchor_id]\n        out = []\n        for _ in range(num_children):\n            pid = self._next_pid\n            self._next_pid += 1\n            self._particles[pid] = P(\n                id=pid,\n                time=float(target_time),\n                parent_id=anchor.particle_id,\n                source_anchor_id=anchor_id,\n            )\n            out.append(pid)\n        return out\n\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            p = self._particles[pid]\n            if p.status == \\\"completed\\\":\n                raise InvalidActionError()\n            p.status = \\\"pruned\\\"\n\n    def answer(self, rule=\\\"best_preview_score\\\"):\n        if rule == \\\"best_preview_score\\\" and self._previews:\n            best = max(self._previews.values(), key=lambda x: x.score)\n            return AnswerRecord(best.particle_id, best.id, (), best.score, self.budget - self._budget_left, rule, [], best.score_dict)\n        active = [p for p in self._particles.values() if p.status \"'!= \"pruned\"]\n        chosen = max(active, key=lambda p: (p.time, p.id)) if active else None\n        return AnswerRecord(None if chosen is None else chosen.id, None, (), None, self.budget - self._budget_left, rule, [], {})\n\n    def get_state(self):\n        return ControllerState(\n            prompt=\"fake\",\n            budget_left=self._budget_left,\n            active_particle_ids=[p.id for p in self._particles.values() if p.status == \"active\"],\n            completed_particle_ids=[p.id for p in self._particles.values() if p.status == \"completed\"],\n            pruned_particle_ids=[p.id for p in self._particles.values() if p.status == \"pruned\"],\n            particles={\n                p.id: ParticleSummary(\n                    id=p.id,\n                    time=p.time,\n                    parent_id=p.parent_id,\n                    source_anchor_id=p.source_anchor_id,\n                    nfe_used=p.nfe_used,\n                    status=p.status,\n                    last_preview_id=p.last_preview_id,\n                    num_children=p.num_children,\n                )\n                for p in self._particles.values()\n            },\n            previews=dict(self._previews),\n            event_log=[],\n        )\n\n\ncontroller = OptimalController()\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = FakeEnv(128)\n    answer = controller.solve(env, beta)\n    print(beta, answer.rule, answer.nfe_used, answer.preview_id)\nPY'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
