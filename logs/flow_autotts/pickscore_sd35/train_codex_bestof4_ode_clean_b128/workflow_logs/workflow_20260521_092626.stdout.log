 min(4, 1 + int(4.0 * beta)),\n    77\t            \"finish_base\": min(4, 1 + int(4.0 * max(0.0, beta - 0.15))),\n    78\t            \"branch_anchors\": 0\n    79\t            + int(beta >= 0.42)\n    80\t            + int(beta >= 0.72)\n    81\t            + int(beta >= 0.94),\n    82\t            \"children\": 0\n    83\t            + int(beta >= 0.42)\n    84\t            + int(beta >= 0.50)\n    85\t            + int(beta >= 0.68)\n    86\t            + int(beta >= 0.82)\n    87\t            + int(beta >= 0.95),\n    88\t            \"late_finishes\": 0 + int(beta >= 0.70) + int(beta >= 0.92),\n    89\t            \"scout_gap\": 0.018 + 0.010 * beta,\n    90\t            \"confirm_gap\": 0.012 + 0.010 * beta,\n    91\t            \"uncertainty\": max(0.12, 0.28 - 0.12 * beta),\n    92\t            \"noise_policy\": \"fresh_noise\"\n    93\t            if beta < 0.42\n    94\t            else (\"inferred_noise\" if beta < 0.80 else \"mixed_noise\"),\n    95\t            \"noise_strength\": max(0.35, 0.95 - 0.50 * beta),\n    96\t        }\n    97\t\n    98\t    def _deterministic_answer(self, env: FlowTTSEnv) -> AnswerRecord:\n    99\t        root_id = env.spawn(1)[0]\n   100\t        try:\n   101\t            self._advance_particle(env, root_id, 1.0)\n   102\t        except (BudgetExceededError, InvalidActionError):\n   103\t            return env.answer(rule=\"latest_active\")\n   104\t        return env.answer(rule=\"latest_active\")\n   105\t\n   106\t    def _advance_batch(self, env: FlowTTSEnv, particle_ids: list[int], target_time: float) -> None:\n   107\t        for particle_id in particle_ids:\n   108\t            self._advance_particle(env, particle_id, target_time)\n   109\t\n   110\t    def _advance_and_preview(self, env: FlowTTSEnv, particle_ids: list[int], target_time: float) -> None:\n   111\t        for particle_id in particle_ids:\n   112\t            state = env.get_state()\n   113\t            particle = state.particles.get(particle_id)\n   114\t            if particle is None or particle.status == \"pruned\":\n   115\t                continue\n   116\t            advanced = self._advance_particle(env, particle_id, target_time)\n   117\t            if env.budget_left <= 0:\n   118\t                return\n   119\t            if advanced and self._needs_preview(env, particle_id):\n   120\t                env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   121\t\n   122\t    def _finish_and_preview(self, env: FlowTTSEnv, particle_ids: list[int]) -> None:\n   123\t        for particle_id in particle_ids:\n   124\t            state = env.get_state()\n   125\t            particle = state.particles.get(particle_id)\n   126\t            if particle is None or particle.status == \"pruned\":\n   127\t                continue\n   128\t            advanced = self._advance_particle(env, particle_id, 1.0)\n   129\t            if env.budget_left <= 0:\n   130\t                return\n   131\t            if (advanced or self._needs_preview(env, particle_id)) and env.budget_left > 0:\n   132\t                env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   133\t\n   134\t    def _refine_contenders(\n   135\t        self,\n   136\t        env: FlowTTSEnv,\n   137\t        ranked: list[PreviewRecord],\n   138\t        schedule: dict[str, float | int | str],\n   139\t    ) -> None:\n   140\t        max_anchors = int(schedule[\"branch_anchors\"])\n   141\t        total_children = int(schedule[\"children\"])\n   142\t        if max_anchors <= 0 or total_children <= 0 or not ranked:\n   143\t            return\n   144\t\n   145\t        gap = self._score_gap(ranked)\n   146\t        uncertainty = float(ranked[0].uncertainty or 0.0)\n   147\t        close_threshold = float(schedule[\"confirm_gap\"])\n   148\t\n   149\t        if gap <= close_threshold * 0.5:\n   150\t            total_children += 1\n   151\t        if uncertainty >= float(schedule[\"uncertainty\"]) and max_anchors > 1:\n   152\t            total_children += 1\n   153\t\n   154\t        contenders = [ranked[0]]\n   155\t        if len(ranked) > 1 and max_anchors > 1:\n   156\t            if gap <= close_threshold or uncertainty >= float(schedule[\"uncertainty\"]):\n   157\t                contenders.append(ranked[1])\n   158\t        if len(ranked) > 2 and max_anchors > 2 and gap <= close_threshold * 0.5:\n   159\t            contenders.append(ranked[2])\n   160\t\n   161\t        child_cost = self._child_finish_preview_cost(env, float(schedule[\"branch_time\"]))\n   162\t        affordable_children = env.budget_left // max(1, child_cost)\n   163\t        total_children = min(total_children, affordable_children)\n   164\t        if total_children <= 0:\n   165\t            return\n   166\t\n   167\t        allocations = self._allocate_children(contenders, total_children, close_threshold, gap)\n   168\t        for preview, num_children in allocations:\n   169\t            if num_children <= 0 or env.budget_left < child_cost:\n   170\t                continue\n   171\t            try:\n   172\t                child_ids = env.backward(\n   173\t                    preview.id,\n   174\t                    target_time=float(schedule[\"branch_time\"]),\n   175\t                    noise_policy=str(schedule[\"noise_policy\"]),\n   176\t                    num_children=num_children,\n   177\t                    strength=float(schedule[\"noise_strength\"]),\n   178\t                )\n   179\t            except (BudgetExceededError, InvalidActionError):\n   180\t                return\n   181\t\n   182\t            self._finish_and_preview(env, child_ids)\n   183\t\n   184\t    def _late_expand(self, env: FlowTTSEnv, schedule: dict[str, float | int | str]) -> None:\n   185\t        remaining = int(schedule[\"late_finishes\"])\n   186\t        if remaining <= 0:\n   187\t            return\n   188\t\n   189\t        while remaining > 0 and env.budget_left > 0:\n   190\t            ranked = self._ranked_previews(env)\n   191\t            if not ranked:\n   192\t                return\n   193\t\n   194\t            gap = self._score_gap(ranked)\n   195\t            uncertainty = float(ranked[0].uncertainty or 0.0)\n   196\t            if gap > float(schedule[\"confirm_gap\"]) * 1.35 and uncertainty < float(schedule[\"uncertainty\"]):\n   197\t                return\n   198\t\n   199\t            candidate_id = self._best_active_ranked_particle(env, ranked)\n   200\t            if candidate_id is None:\n   201\t                return\n   202\t\n   203\t            finish_cost = self._finish_preview_cost(env, candidate_id)\n   204\t            if finish_cost <= 0 or env.budget_left < finish_cost:\n   205\t                return\n   206\t\n   207\t            self._finish_and_preview(env, [candidate_id])\n   208\t            remaining -= 1\n   209\t\n   210\t    def _select_particle_ids(\n   211\t        self,\n   212\t        ranked: list[PreviewRecord],\n   213\t        base: int,\n   214\t        gap_threshold: float,\n   215\t        uncertainty_threshold: float,\n   216\t    ) -> set[int]:\n   217\t        if not ranked:\n   218\t            return set()\n   219\t\n   220\t        keep = min(len(ranked), max(1, base))\n   221\t        gap = self._score_gap(ranked)\n   222\t        top_uncertainty = float(ranked[0].uncertainty or 0.0)\n   223\t\n   224\t        if gap <= gap_threshold:\n   225\t            keep += 1\n   226\t        if top_uncertainty >= uncertainty_threshold:\n   227\t            keep += 1\n   228\t\n   229\t        keep = min(len(ranked), max(1, keep))\n   230\t        return {preview.particle_id for preview in ranked[:keep]}\n   231\t\n   232\t    def _allocate_children(\n   233\t        self,\n   234\t        contenders: list[PreviewRecord],\n   235\t        total_children: int,\n   236\t        close_threshold: float,\n   237\t        gap: float,\n   238\t    ) -> list[tuple[PreviewRecord, int]]:\n   239\t        if not contenders or total_children <= 0:\n   240\t            return []\n   241\t        if len(contenders) == 1:\n   242\t            return [(contenders[0], total_children)]\n   243\t\n   244\t        if len(contenders) == 2:\n   245\t            if gap <= close_threshold * 0.5:\n   246\t                first = (total_children + 1) // 2\n   247\t            else:\n   248\t                first = max(1, (3 * total_children + 1) // 4)\n   249\t            second = max(0, total_children - first)\n   250\t            result = [(contenders[0], first)]\n   251\t            if second > 0:\n   252\t                result.append((contenders[1], second))\n   253\t            return result\n   254\t\n   255\t        allocations: list[tuple[PreviewRecord, int]] = []\n   256\t        remaining = total_children\n   257\t        for index, preview in enumerate(contenders):\n   258\t            slots_left = len(contenders) - index\n   259\t            count = max(1, remaining - (slots_left - 1))\n   260\t            allocations.append((preview, count))\n","exit_code":0,"status":"completed"}}
