me + 1e-9:\n   300\t                env.forward(particle_id, target_time=grid_time, solver=\"euler\")\n   301\t                current_time = grid_time\n   302\t        return current_time > start_time + 1e-9\n   303\t\n   304\t    def _ranked_previews(self, env: FlowTTSEnv) -> list[PreviewRecord]:\n   305\t        state = env.get_state()\n   306\t        latest_by_particle: dict[int, PreviewRecord] = {}\n   307\t        for particle in state.particles.values():\n   308\t            if particle.status == \"pruned\" or particle.last_preview_id is None:\n   309\t                continue\n   310\t            preview = state.previews.get(particle.last_preview_id)\n   311\t            if preview is None or preview.score is None:\n   312\t                continue\n   313\t            latest_by_particle[particle.id] = preview\n   314\t        return sorted(\n   315\t            latest_by_particle.values(),\n   316\t            key=lambda preview: (\n   317\t                float(preview.score),\n   318\t                -float(preview.uncertainty or 0.0),\n   319\t                float(preview.time),\n   320\t            ),\n   321\t            reverse=True,\n   322\t        )\n   323\t\n   324\t    def _needs_preview(self, env: FlowTTSEnv, particle_id: int) -> bool:\n   325\t        state = env.get_state()\n   326\t        particle = state.particles.get(particle_id)\n   327\t        if particle is None:\n   328\t            return False\n   329\t        if particle.last_preview_id is None:\n   330\t            return True\n   331\t        preview = state.previews.get(particle.last_preview_id)\n   332\t        if preview is None:\n   333\t            return True\n   334\t        return float(preview.time) + 1e-9 < float(particle.time)\n   335\t\n   336\t    def _best_active_ranked_particle(\n   337\t        self,\n   338\t        env: FlowTTSEnv,\n   339\t        ranked: list[PreviewRecord],\n   340\t    ) -> int | None:\n   341\t        state = env.get_state()\n   342\t        for preview in ranked:\n   343\t            particle = state.particles.get(preview.particle_id)\n   344\t            if particle is None:\n   345\t                continue\n   346\t            if particle.status == \"active\" and float(particle.time) < 1.0 - 1e-9:\n   347\t                return particle.id\n   348\t        return None\n   349\t\n   350\t    def _score_gap(self, ranked: list[PreviewRecord]) -> float:\n   351\t        if len(ranked) < 2:\n   352\t            return float(\"inf\")\n   353\t        return float(ranked[0].score or 0.0) - float(ranked[1].score or 0.0)\n   354\t\n   355\t    def _forward_cost_from_time(self, env: FlowTTSEnv, start_time: float, target_time: float) -> int:\n   356\t        if target_time <= start_time:\n   357\t            return 0\n   358\t        return sum(\n   359\t            1\n   360\t            for grid_time in env.time_grid\n   361\t            if float(grid_time) > start_time + 1e-9 and float(grid_time) <= target_time + 1e-9\n   362\t        )\n   363\t\n   364\t    def _child_finish_preview_cost(self, env: FlowTTSEnv, target_time: float) -> int:\n   365\t        return self._forward_cost_from_time(env, target_time, 1.0) + 1\n   366\t\n   367\t    def _finish_preview_cost(self, env: FlowTTSEnv, particle_id: int) -> int:\n   368\t        state = env.get_state()\n   369\t        particle = state.particles.get(particle_id)\n   370\t        if particle is None or particle.status == \"pruned\":\n   371\t            return 0\n   372\t        forward_cost = self._forward_cost_from_time(env, float(particle.time), 1.0)\n   373\t        preview_cost = 1 if self._needs_preview(env, particle_id) else 0\n   374\t        return forward_cost + preview_cost\n   375\t\n   376\t    def _grid_index(self, grid_last: int, fraction: float) -> int:\n   377\t        fraction = min(max(float(fraction), 0.0), 1.0)\n   378\t        return min(grid_last, max(1, int(grid_last * fraction + 1e-9)))\n   379\t\n   380\t    def _grid_time(self, env: FlowTTSEnv, index: int) -> float:\n   381\t        index = min(max(0, int(index)), len(env.time_grid) - 1)\n   382\t        return float(env.time_grid[index])\n   383\t\n   384\t    def _answer(self, env: FlowTTSEnv) -> AnswerRecord:\n   385\t        state = env.get_state()\n   386\t        if state.previews:\n   387\t            try:\n   388\t                return env.answer(rule=\"best_preview_score\")\n   389\t            except InvalidActionError:\n   390\t                pass\n   391\t        return env.answer(rule=\"latest_active\")\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_34","type":"agent_message","text":"Implemented a new tournament-style controller in [optimal.py](/inspire/hdd/global_user/gongjingjing-25039/sywang/jkcai/FlowEvo/flow_autotts/controllers/optimal.py#L10). The policy is: spawn multiple roots, scout them at mid time, prune losers, confirm only survivors later, finish only finalists, then spend backward budget with a champion-challenger allocator that splits children across the top 1-3 anchors only when the confirmed score gap is small or uncertainty is high. That directly targets the `r0003` weakness where beta `0.5/0.75/1.0` lost to nearest ODE while spending mostly on previews and only a little on backward refinement.\n\nI inspected the compact baseline table in the context pack, the frontier rows for `r0003` (`beta=0.0/0.25/0.5/0.75/1.0`, rewards `0.8192/0.8308/0.8365/0.8405/0.8432`, mean NFE `10/26/43.4/65.1/94.8`), and the `r0003`, `r0002`, and `r0001` controller snapshots/summaries. Relative to ODE, only `beta=0.0` and `0.25` were winning; `0.5`, `0.75`, and `1.0` were still behind. The last two successful snapshots were the same scout-confirm-branch family with timing/threshold shifts; this round changes the mechanism itself.\n\nThe exact schedule is in [optimal.py](/inspire/hdd/global_user/gongjingjing-25039/sywang/jkcai/FlowEvo/flow_autotts/controllers/optimal.py#L65). Budget use is monotone because all spend-driving knobs are nondecreasing in beta: `roots`, `keep_base`, `finish_base`, `branch_anchors`, `children`, `late_finishes`, plus later confirmation and earlier backward target times for stronger local search. Concretely:\n- `beta=0.0`: deterministic one-root finish only, near 10 NFE.\n- `beta=0.25`: `roots=2`, `keep_base=2`, `finish_base=1`, no backward, no late finishes.\n- `beta=0.5`: `roots=4`, `keep_base=3`, `finish_base=2`, `branch_anchors=1`, `children=2`.\n- `beta=0.75`: `roots=6`, `keep_base=4`, `finish_base=3`, `branch_anchors=2`, `children=3`, `late_finishes=1`.\n- `beta=1.0`: `roots=7`, `keep_base=4`, `finish_base=4`, `branch_anchors=3`, `children=5`, `late_finishes=2`.\nTimes are smooth functions of beta: `scout_time=grid(0.38+0.10*beta)`, `confirm_time=grid(0.74+0.08*beta)`, `branch_time=grid(0.78-0.20*beta)`.\n\nBehaviorally new versus the recent best:\n- Multi-root mid-time tournament instead of mostly single-root preview accumulation.\n- Confirmed-gap child allocation: decisive winner gets most children; close contests split children across top two or three anchors.\n- Late budget goes to finishing ranked active contenders, not just more confirmation previews.\n- Noise policy now changes by regime: `fresh_noise` at low beta, `inferred_noise` at mid beta, `mixed_noise` at high beta.\n\nChecks run:\n- `python3 -m py_compile flow_autotts/controllers/optimal.py`\n- `python3` fake-env dry run over betas `0.0/0.25/0.5/0.75/1.0`; it terminated correctly with monotone spend (`10/26/63/90/119` NFE in the stub). I did not run the full SD3.5 eval.\n\nTarget-NFE reflection:\n- `beta=0.0`: underuse is justified; I left it deterministic.\n- `beta=0.25`: previous low-beta already beat ODE, so I kept it lean; no artificial top-off.\n- `beta=0.5`: this was a weak region, so I increased width and added selective backward on confirmed winners; this is an intentional utilization increase, not filler.\n- `beta=0.75`: prior controller looked underused relative to available budget and still trailed ODE; I added second-anchor refinement and one late finish.\n- `beta=1.0`: prior controller still trailed ODE below the budget ceiling; I pushed utilization upward with more roots, more anchors, more children, and two late finishes.\n\nMain risks are that mid-time previews may still be noisy enough to mis-rank roots at `beta=0.5`, and the wider tournament could overspend if extra diversity does not translate into better finalists. The proposal is specifically aimed at improving the `beta=0.5`, `0.75`, and `1.0` frontier rows while preserving the existing `beta=0.25` strength."}}
