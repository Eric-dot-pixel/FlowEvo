{"type":"item.completed","item":{"id":"item_30","type":"command_execution","command":"/bin/bash -lc \"nl -ba flow_autotts/controllers/optimal.py | sed -n '1,260p'\"","aggregated_output":"     1\t\"\"\"Candidate controller for SD3.5 PickScore discovery.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom flow_autotts.core.env import FlowTTSEnv\n     6\tfrom flow_autotts.core.errors import BudgetExceededError, InvalidActionError\n     7\tfrom flow_autotts.core.state import AnswerRecord, PreviewRecord\n     8\t\n     9\t\n    10\tclass OptimalController:\n    11\t    \"\"\"Scout width first, then confirm, then locally refine uncertain winners.\"\"\"\n    12\t\n    13\t    def solve(self, env: FlowTTSEnv, beta: float) -> AnswerRecord:\n    14\t        beta = min(max(float(beta), 0.0), 1.0)\n    15\t        schedule = self._schedule(env, beta)\n    16\t\n    17\t        if beta <= 0.0:\n    18\t            return self._deterministic_answer(env)\n    19\t\n    20\t        try:\n    21\t            root_ids = env.spawn(int(schedule[\"roots\"]))\n    22\t            self._advance_batch(env, root_ids, float(schedule[\"scout_time\"]))\n    23\t            self._preview_batch(env, root_ids)\n    24\t\n    25\t            ranked = self._ranked_previews(env)\n    26\t            if not ranked:\n    27\t                return self._answer(env)\n    28\t\n    29\t            keep_ids = self._select_survivors(ranked, schedule)\n    30\t            self._prune_except(env, root_ids, keep_ids)\n    31\t\n    32\t            self._confirm_survivors(env, keep_ids, schedule)\n    33\t            ranked = self._ranked_previews(env)\n    34\t            if not ranked:\n    35\t                return self._answer(env)\n    36\t\n    37\t            self._finish_selected_roots(env, ranked, schedule)\n    38\t            ranked = self._ranked_previews(env)\n    39\t            if not ranked:\n    40\t                return self._answer(env)\n    41\t\n    42\t            self._refine_with_backward(env, ranked, schedule)\n    43\t            ranked = self._ranked_previews(env)\n    44\t            if not ranked:\n    45\t                return self._answer(env)\n    46\t\n    47\t            self._late_rechecks(env, ranked, schedule)\n    48\t        except (BudgetExceededError, InvalidActionError):\n    49\t            return self._answer(env)\n    50\t\n    51\t        return self._answer(env)\n    52\t\n    53\t    def _schedule(self, env: FlowTTSEnv, beta: float) -> dict[str, float | int]:\n    54\t        grid_last = max(1, len(env.time_grid) - 1)\n    55\t\n    56\t        if beta <= 0.0:\n    57\t            return {\n    58\t                \"roots\": 1,\n    59\t                \"scout_time\": 1.0,\n    60\t                \"confirm_time\": 1.0,\n    61\t                \"finish_time\": 1.0,\n    62\t                \"branch_time\": 0.85,\n    63\t                \"keep\": 1,\n    64\t                \"finish_roots\": 1,\n    65\t                \"branch_anchors\": 0,\n    66\t                \"children\": 0,\n    67\t                \"late_passes\": 0,\n    68\t                \"score_gap\": 0.02,\n    69\t                \"finish_gap\": 0.02,\n    70\t                \"branch_gap\": 0.01,\n    71\t                \"uncertainty\": 0.45,\n    72\t                \"noise_policy\": \"inferred_noise\",\n    73\t                \"noise_strength\": 0.55,\n    74\t            }\n    75\t\n    76\t        scout_fraction = 0.20 + 0.10 * beta\n    77\t        confirm_fraction = 0.52 + 0.18 * beta\n    78\t        finish_fraction = 0.88 + 0.10 * beta\n    79\t\n    80\t        roots = 2 + int(beta >= 0.35) + int(beta >= 0.65) + int(beta >= 0.90)\n    81\t        keep = 1 + int(beta >= 0.22) + int(beta >= 0.60) + int(beta >= 0.88)\n    82\t        finish_roots = 1 + int(beta >= 0.50) + int(beta >= 0.82)\n    83\t        branch_anchors = int(beta >= 0.28) + int(beta >= 0.58) + int(beta >= 0.88)\n    84\t        children = int(beta >= 0.28) + int(beta >= 0.72) + int(beta >= 0.92)\n    85\t        late_passes = int(beta >= 0.58) + int(beta >= 0.86)\n    86\t\n    87\t        branch_fraction = 0.82 - 0.18 * beta\n    88\t        branch_fraction = max(0.58, min(branch_fraction, 0.86))\n    89\t        noise_policy = \"inferred_noise\" if beta < 0.42 else \"mixed_noise\"\n    90\t        noise_strength = 0.58 - 0.22 * beta\n    91\t\n    92\t        return {\n    93\t            \"roots\": roots,\n    94\t            \"scout_time\": self._grid_time(env, self._grid_index(grid_last, scout_fraction)),\n    95\t            \"confirm_time\": self._grid_time(env, self._grid_index(grid_last, confirm_fraction)),\n    96\t            \"finish_time\": self._grid_time(env, self._grid_index(grid_last, finish_fraction)),\n    97\t            \"branch_time\": self._grid_time(env, self._grid_index(grid_last, branch_fraction)),\n    98\t            \"keep\": keep,\n    99\t            \"finish_roots\": finish_roots,\n   100\t            \"branch_anchors\": branch_anchors,\n   101\t            \"children\": children,\n   102\t            \"late_passes\": late_passes,\n   103\t            \"score_gap\": 0.010 + 0.010 * beta,\n   104\t            \"finish_gap\": 0.018 + 0.010 * beta,\n   105\t            \"branch_gap\": 0.006 + 0.010 * beta,\n   106\t            \"uncertainty\": 0.18 + 0.16 * beta,\n   107\t            \"noise_policy\": noise_policy,\n   108\t            \"noise_strength\": max(0.20, noise_strength),\n   109\t        }\n   110\t\n   111\t    def _deterministic_answer(self, env: FlowTTSEnv) -> AnswerRecord:\n   112\t        root_id = env.spawn(1)[0]\n   113\t        try:\n   114\t            self._advance_particle(env, root_id, 1.0)\n   115\t        except (BudgetExceededError, InvalidActionError):\n   116\t            return env.answer(rule=\"latest_active\")\n   117\t        return env.answer(rule=\"latest_active\")\n   118\t\n   119\t    def _advance_batch(self, env: FlowTTSEnv, particle_ids: list[int], target_time: float) -> None:\n   120\t        for particle_id in particle_ids:\n   121\t            self._advance_particle(env, particle_id, target_time)\n   122\t\n   123\t    def _advance_particle(self, env: FlowTTSEnv, particle_id: int, target_time: float) -> None:\n   124\t        state = env.get_state()\n   125\t        particle = state.particles.get(particle_id)\n   126\t        if particle is None or particle.status == \"pruned\":\n   127\t            return\n   128\t\n   129\t        current_time = float(particle.time)\n   130\t        for grid_time in env.time_grid:\n   131\t            grid_time = float(grid_time)\n   132\t            if grid_time > current_time + 1e-9 and grid_time <= target_time + 1e-9:\n   133\t                env.forward(particle_id, target_time=grid_time, solver=\"euler\")\n   134\t                current_time = grid_time\n   135\t\n   136\t    def _preview_batch(self, env: FlowTTSEnv, particle_ids: list[int]) -> None:\n   137\t        for particle_id in particle_ids:\n   138\t            if env.budget_left <= 0:\n   139\t                return\n   140\t            try:\n   141\t                env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   142\t            except (BudgetExceededError, InvalidActionError):\n   143\t                return\n   144\t\n   145\t    def _select_survivors(\n   146\t        self,\n   147\t        ranked: list[PreviewRecord],\n   148\t        schedule: dict[str, float | int],\n   149\t    ) -> set[int]:\n   150\t        if not ranked:\n   151\t            return set()\n   152\t\n   153\t        keep = int(schedule[\"keep\"])\n   154\t        gap = self._score_gap(ranked)\n   155\t        top_uncertainty = float(ranked[0].uncertainty or 0.0)\n   156\t        if gap <= float(schedule[\"score_gap\"]):\n   157\t            keep += 1\n   158\t        if top_uncertainty >= float(schedule[\"uncertainty\"]):\n   159\t            keep += 1\n   160\t        keep = min(len(ranked), max(1, keep))\n   161\t        return {preview.particle_id for preview in ranked[:keep]}\n   162\t\n   163\t    def _prune_except(self, env: FlowTTSEnv, particle_ids: list[int], keep_ids: set[int]) -> None:\n   164\t        losers = [particle_id for particle_id in particle_ids if particle_id not in keep_ids]\n   165\t        if not losers:\n   166\t            return\n   167\t        try:\n   168\t            env.prune(losers)\n   169\t        except InvalidActionError:\n   170\t            return\n   171\t\n   172\t    def _confirm_survivors(\n   173\t        self,\n   174\t        env: FlowTTSEnv,\n   175\t        keep_ids: set[int],\n   176\t        schedule: dict[str, float | int],\n   177\t    ) -> None:\n   178\t        target_time = float(schedule[\"confirm_time\"])\n   179\t        for particle_id in list(keep_ids):\n   180\t            if env.budget_left <= 0:\n   181\t                return\n   182\t            state = env.get_state()\n   183\t            particle = state.particles.get(particle_id)\n   184\t            if particle is None or particle.status == \"pruned\":\n   185\t                continue\n   186\t            try:\n   187\t                self._advance_particle(env, particle_id, target_time)\n   188\t                if env.budget_left > 0:\n   189\t                    env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   190\t            except (BudgetExceededError, InvalidActionError):\n   191\t                continue\n   192\t\n   193\t    def _finish_selected_roots(\n   194\t        self,\n   195\t        env: FlowTTSEnv,\n   196\t        ranked: list[PreviewRecord],\n   197\t        schedule: dict[str, float | int],\n   198\t    ) -> None:\n   199\t        if not ranked:\n   200\t            return\n   201\t\n   202\t        finish_count = min(len(ranked), max(1, int(schedule[\"finish_roots\"])))\n   203\t        gap = self._score_gap(ranked)\n   204\t        top_uncertainty = float(ranked[0].uncertainty or 0.0)\n   205\t        if gap <= float(schedule[\"finish_gap\"]):\n   206\t            finish_count = min(len(ranked), finish_count + 1)\n   207\t        if top_uncertainty >= float(schedule[\"uncertainty\"]):\n   208\t            finish_count = min(len(ranked), finish_count + 1)\n   209\t\n   210\t        for preview in ranked[:finish_count]:\n   211\t            if env.budget_left <= 0:\n   212\t                return\n   213\t            try:\n   214\t                self._advance_particle(env, preview.particle_id, 1.0)\n   215\t                if env.budget_left > 0:\n   216\t                    env.preview(preview.particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   217\t            except (BudgetExceededError, InvalidActionError):\n   218\t                continue\n   219\t\n   220\t    def _refine_with_backward(\n   221\t        self,\n   222\t        env: FlowTTSEnv,\n   223\t        ranked: list[PreviewRecord],\n   224\t        schedule: dict[str, float | int],\n   225\t    ) -> None:\n   226\t        anchor_budget = int(schedule[\"branch_anchors\"])\n   227\t        child_budget = int(schedule[\"children\"])\n   228\t        if anchor_budget <= 0 or child_budget <= 0 or not ranked:\n   229\t            return\n   230\t\n   231\t        chosen = self._choose_branch_anchors(ranked, schedule, anchor_budget)\n   232\t        target_time = float(schedule[\"branch_time\"])\n   233\t        finish_time = float(schedule[\"finish_time\"])\n   234\t\n   235\t        for index, anchor in enumerate(chosen):\n   236\t            if env.budget_left <= 0:\n   237\t                return\n   238\t\n   239\t            num_children = child_budget\n   240\t            if index > 0:\n   241\t                num_children = max(1, num_children - 1)\n   242\t            if (\n   243\t                index == 0\n   244\t                and len(ranked) > 1\n   245\t                and self._score_gap(ranked) <= float(schedule[\"branch_gap\"])\n   246\t            ):\n   247\t                num_children += 1\n   248\t\n   249\t            try:\n   250\t                child_ids = env.backward(\n   251\t                    anchor.id,\n   252\t                    target_time=target_time,\n   253\t                    noise_policy=str(schedule[\"noise_policy\"]),\n   254\t                    num_children=num_children,\n   255\t                    strength=float(schedule[\"noise_strength\"]),\n   256\t                )\n   257\t            except (BudgetExceededError, InvalidActionError):\n   258\t                return\n   259\t\n   260\t            for child_id in child_ids:\n","exit_code":0,"status":"completed"}}
