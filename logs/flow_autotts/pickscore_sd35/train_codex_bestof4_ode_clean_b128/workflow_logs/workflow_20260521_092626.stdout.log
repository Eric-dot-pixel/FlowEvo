     self._particles[pid]=DummyParticle(id=pid, time=float(target_time), status='active' if target_time < 1.0 else 'completed', last_preview_id=None)\n            ids.append(pid)\n        return ids\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            self._particles[pid].status='pruned'\n    def answer(self, rule='best_preview_score'):\n        return SimpleNamespace(rule=rule, nfe_used=self.budget - self.budget_left, preview_count=len(self._previews))\n    def get_state(self):\n        return DummyState(particles={pid:p for pid,p in self._particles.items()}, previews={aid:p for aid,p in self._previews.items()}, budget_left=self.budget_left)\n\nctrl = OptimalController()\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = DummyEnv()\n    ans = ctrl.solve(env, beta)\n    print(beta, ans.rule, ans.nfe_used, env.budget_left, ans.preview_count)\nPY\"","aggregated_output":"0.0 latest_active 10 118 0\n0.25 best_preview_score 30 98 8\n0.5 best_preview_score 48 80 12\n0.75 best_preview_score 66 62 17\n1.0 best_preview_score 93 35 25\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_37","type":"agent_message","text":"Controller: preview-gated multi-root scout/confirm/refine with score-gap + uncertainty pruning, then beta-scaled top-off branching. It targets the mid/high-beta weakness where the prior policy spent mostly on one finished root and still lost to ODE at `beta=0.5/0.75/1.0`.\n\nInspected: [context pack]( /inspire/hdd/global_user/gongjingjing-25039/sywang/jkcai/FlowEvo/logs/flow_autotts/pickscore_sd35/train_codex_bestof4_ode_clean_b128/codex_logs/r0001_20260521_092626_8464683a/context_pack.md ), [archived r0000 controller]( /inspire/hdd/global_user/gongjingjing-25039/sywang/jkcai/FlowEvo/logs/flow_autotts/pickscore_sd35/train_codex_bestof4_ode_clean_b128/history/r0000_20260521_092626_8464683a/flow_autotts/controllers/optimal.py ), current [optimal.py]( /inspire/hdd/global_user/gongjingjing-25039/sywang/jkcai/FlowEvo/flow_autotts/controllers/optimal.py ), and the baseline/frontier rows in `context_pack.md`. Nearest ODE baseline comparison: `beta=0.0` and `0.25` beat baseline; `0.5/0.75/1.0` did not.\n\nSchedule: `scouts = 1 + [b>0] + [b>=0.2] + [b>=0.45] + [b>=0.7] + [b>=0.9]`; keep/branch/child counts all rise monotonically with beta; probe times shift later with beta; target spend uses `target_nfe = budget * (0.09 + 0.34b + 0.28b^2)` capped by budget. That makes higher beta strictly more willing to spend compute, while low beta stays near ODE-like behavior.\n\nNovelty: this is not just a threshold tweak. It adds beta-conditioned multi-root scouting, explicit confirmation, score-gap-aware pruning, and a late top-off pass that only spends extra budget when preview evidence remains ambiguous.\n\nChecks: `python3 -m py_compile flow_autotts/controllers/optimal.py`; tiny fake-env dry-run across `beta = 0.0, 0.25, 0.5, 0.75, 1.0` hit all branches.\n\nPer beta: `0.0` early stop is justified; `0.25` stays conservative with limited scouting; `0.5`, `0.75`, `1.0` were underusing target NFE before, so I adjusted them upward with more scouts, more keepers/children, and a top-off pass. Risks: over-branching on noisy early previews, or still not fully closing the gap at `beta >= 0.75` if the score signal is flat."}}
