{"type":"item.started","item":{"id":"item_32","type":"command_execution","command":"/bin/bash -lc \"python3 - <<'PY'\nfrom types import SimpleNamespace\nfrom flow_autotts.controllers.optimal import OptimalController\n\nclass P:\n    def __init__(self, pid, time=0.0, status='active', last_preview_id=None):\n        self.id=pid; self.time=time; self.status=status; self.last_preview_id=last_preview_id\n\nclass Prev:\n    def __init__(self, pid, particle_id, score, uncertainty=0.1, time=0.2):\n        self.id=pid; self.particle_id=particle_id; self.score=score; self.uncertainty=uncertainty; self.time=time\n\nclass State:\n    def __init__(self, particles, previews):\n        self.particles=particles; self.previews=previews\n\nclass Env:\n    def __init__(self):\n        self.time_grid=(0.0,0.25,0.5,0.75,1.0)\n        self.budget=50\n        self.budget_left=50\n        self._next=0\n        self._particles={}\n        self._previews={}\n    def get_state(self):\n        return State(dict(self._particles), dict(self._previews))\n    def spawn(self,n):\n        out=[]\n        for _ in range(n):\n            pid=self._next; self._next+=1; out.append(pid); self._particles[pid]=P(pid)\n        return out\n    def forward(self, particle_id, target_time, solver='euler', cfg=None):\n        p=self._particles[particle_id]; p.time=target_time\n        self.budget_left-=1\n        if target_time>=1.0: p.status='completed'\n        return p\n    def preview(self, particle_id, mode='clean_anchor', scorer='default'):\n        pid=len(self._previews)\n        p=self._particles[particle_id]\n        p.last_preview_id=pid\n        self._previews[pid]=Prev(pid, particle_id, score=float(particle_id)+p.time, uncertainty=0.1, time=p.time)\n        self.budget_left-=1\n        return self._previews[pid]\n    def backward(self, anchor_id, target_time, noise_policy='fresh_noise', num_children=1, mask=None, strength=1.0):\n        out=[]\n        for _ in range(num_children):\n            pid=self._next; self._next+=1; out.append(pid); self._particles[pid]=P(pid, time=target_time)\n        return out\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            self._particles[pid].status='pruned'\n    def answer(self, rule='best_preview_score'):\n        return SimpleNamespace(rule=rule, nfe_used=self.budget-self.budget_left)\n\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env=Env()\n    res=OptimalController().solve(env, beta)\n    print(beta, res.rule, res.nfe_used, env.budget_left)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
