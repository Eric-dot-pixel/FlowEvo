 41\t                return self._answer_fallback(env, beta)\n    42\t\n    43\t            confirm_time = float(schedule[\"confirm_time\"])\n    44\t            if confirm_time > float(schedule[\"scout_time\"]) and beta >= 0.25:\n    45\t                self._confirm_survivors(env, keep_ids, confirm_time, schedule, beta)\n    46\t                ranked = self._ranked_previews(env)\n    47\t                if not ranked:\n    48\t                    return self._answer_fallback(env, beta)\n    49\t\n    50\t            branch_budget = self._branch_budget(beta)\n    51\t            if branch_budget > 0:\n    52\t                self._branch_and_refine(env, ranked, schedule, beta, initial_budget, branch_budget)\n    53\t\n    54\t            if beta >= 0.6:\n    55\t                self._late_confirmation(env, ranked, schedule, initial_budget, beta)\n    56\t\n    57\t        except (BudgetExceededError, InvalidActionError):\n    58\t            return env.answer(rule=\"latest_active\")\n    59\t\n    60\t        return env.answer(rule=\"best_preview_score\")\n    61\t\n    62\t    def _schedule(self, env: FlowTTSEnv, beta: float) -> dict[str, float | int]:\n    63\t        grid_last = max(1, len(env.time_grid) - 1)\n    64\t        scout_idx = self._grid_index(grid_last, 0.12 + 0.10 * beta)\n    65\t        confirm_idx = self._grid_index(grid_last, 0.42 + 0.20 * beta)\n    66\t        branch_idx = self._grid_index(grid_last, 0.68 + 0.12 * beta)\n    67\t        finish_idx = self._grid_index(grid_last, 0.88 + 0.08 * beta)\n    68\t\n    69\t        roots = 1 + int(beta >= 0.20) + int(beta >= 0.55) + int(beta >= 0.85)\n    70\t        scout_preview_cap = 1 + int(beta >= 0.20) + int(beta >= 0.50) + int(beta >= 0.80)\n    71\t        keep_base = 1 + int(beta >= 0.30) + int(beta >= 0.65)\n    72\t        branch_children = 1 + int(beta >= 0.55) + int(beta >= 0.85)\n    73\t        max_branch_anchors = 0\n    74\t        if beta >= 0.25:\n    75\t            max_branch_anchors += 1\n    76\t        if beta >= 0.60:\n    77\t            max_branch_anchors += 1\n    78\t        if beta >= 0.90:\n    79\t            max_branch_anchors += 1\n    80\t\n    81\t        return {\n    82\t            \"roots\": roots,\n    83\t            \"scout_time\": self._grid_time(env, scout_idx),\n    84\t            \"confirm_time\": self._grid_time(env, confirm_idx),\n    85\t            \"branch_time\": self._grid_time(env, branch_idx),\n    86\t            \"finish_time\": self._grid_time(env, finish_idx),\n    87\t            \"scout_preview_cap\": scout_preview_cap,\n    88\t            \"keep_base\": keep_base,\n    89\t            \"branch_children\": branch_children,\n    90\t            \"max_branch_anchors\": max_branch_anchors,\n    91\t            \"score_gap\": 0.008 + 0.012 * beta,\n    92\t            \"uncertainty\": 0.30 + 0.22 * beta,\n    93\t            \"noise_policy\": \"inferred_noise\" if beta < 0.50 else \"mixed_noise\",\n    94\t            \"noise_strength\": 0.88 - 0.38 * beta,\n    95\t            \"topoff_passes\": 0 if beta < 0.45 else 1 + int(beta >= 0.80),\n    96\t        }\n    97\t\n    98\t    def _answer_fallback(self, env: FlowTTSEnv, beta: float) -> AnswerRecord:\n    99\t        if beta <= 0.0:\n   100\t            return env.answer(rule=\"latest_active\")\n   101\t        ranked = self._ranked_previews(env)\n   102\t        if ranked:\n   103\t            return env.answer(rule=\"best_preview_score\")\n   104\t        return env.answer(rule=\"latest_active\")\n   105\t\n   106\t    def _advance_to(self, env: FlowTTSEnv, particle_ids: list[int], target_time: float, allow_stop: bool = False) -> None:\n   107\t        for particle_id in particle_ids:\n   108\t            self._advance_particle(env, particle_id, target_time, allow_stop=allow_stop)\n   109\t\n   110\t    def _advance_particle(self, env: FlowTTSEnv, particle_id: int, target_time: float, allow_stop: bool = False) -> None:\n   111\t        state = env.get_state()\n   112\t        current_time = float(state.particles[particle_id].time)\n   113\t        for grid_time in env.time_grid:\n   114\t            if grid_time > current_time + 1e-9 and grid_time <= target_time + 1e-9:\n   115\t                if allow_stop and self._unsafe_to_continue(env, particle_id):\n   116\t                    return\n   117\t                env.forward(particle_id, target_time=float(grid_time), solver=\"euler\")\n   118\t                current_time = float(grid_time)\n   119\t\n   120\t    def _preview_batch(self, env: FlowTTSEnv, particle_ids: list[int]) -> None:\n   121\t        for particle_id in particle_ids:\n   122\t            if env.budget_left <= 0:\n   123\t                return\n   124\t            env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n   125\t\n   126\t    def _select_keep_ids(\n   127\t        self,\n   128\t        ranked: list[PreviewRecord],\n   129\t        schedule: dict[str, float | int],\n   130\t        beta: float,\n   131\t    ) -> set[int]:\n   132\t        keep = int(schedule[\"keep_base\"])\n   133\t        gap = self._score_gap(ranked)\n   134\t        top_uncertainty = float(ranked[0].uncertainty or 0.0)\n   135\t        if gap <= float(schedule[\"score_gap\"]):\n   136\t            keep += 1\n   137\t        if top_uncertainty >= float(schedule[\"uncertainty\"]):\n   138\t            keep += 1\n   139\t        if beta >= 0.85 and len(ranked) > 2:\n   140\t            keep += 1\n   141\t        keep = max(1, min(len(ranked), keep))\n   142\t        return {preview.particle_id for preview in ranked[:keep]}\n   143\t\n   144\t    def _prune_roots(self, env: FlowTTSEnv, root_ids: list[int], keep_ids: set[int]) -> None:\n   145\t        losers = [particle_id for particle_id in root_ids if particle_id not in keep_ids]\n   146\t        if losers:\n   147\t            env.prune(losers)\n   148\t\n   149\t    def _confirm_survivors(\n   150\t        self,\n   151\t        env: Flow