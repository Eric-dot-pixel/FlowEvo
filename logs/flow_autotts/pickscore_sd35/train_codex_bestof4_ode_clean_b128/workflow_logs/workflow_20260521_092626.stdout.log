{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/bash -lc \"python - <<'PY'\nfrom flow_autotts.controllers.optimal import OptimalController\nfrom flow_autotts.core.errors import BudgetExceededError, InvalidActionError\nfrom flow_autotts.core.state import AnswerRecord, ControllerState, EventRecord, ParticleSummary, PreviewRecord\n\nclass FakeEnv:\n    def __init__(self, budget=128):\n        self.time_grid = tuple(i / 10 for i in range(11))\n        self.budget = budget\n        self._budget_left = budget\n        self._next_particle = 0\n        self._next_preview = 0\n        self._particles = {}\n        self._previews = {}\n        self._answered = False\n\n    @property\n    def budget_left(self):\n        return self._budget_left\n\n    def spawn(self, n):\n        ids = []\n        for _ in range(n):\n            pid = self._next_particle\n            self._next_particle += 1\n            self._particles[pid] = {\n                'id': pid,\n                'time': 0.0,\n                'parent_id': None,\n                'source_anchor_id': None,\n                'nfe_used': 0,\n                'status': 'active',\n                'last_preview_id': None,\n                'num_children': 0,\n            }\n            ids.append(pid)\n        return ids\n\n    def forward(self, particle_id, target_time, solver='euler', cfg=None):\n        p = self._particles[particle_id]\n        if p['status'] == 'pruned':\n            raise InvalidActionError('pruned')\n        if target_time <= p['time']:\n            raise InvalidActionError('non advancing')\n        cost = sum(1 for t in self.time_grid if p['time'] < t <= target_time)\n        if self._budget_left < cost:\n            raise BudgetExceededError()\n        self._budget_left -= cost\n        p['time'] = target_time\n        p['nfe_used'] += cost\n        if target_time >= 1.0:\n            p['status'] = 'completed'\n        return self.get_state().particles[particle_id]\n\n    def preview(self, particle_id, mode='clean_anchor', scorer='default'):\n        p = self._particles[particle_id]\n        if p['status'] == 'pruned':\n            raise InvalidActionError('pruned preview')\n        if self._budget_left < 1:\n            raise BudgetExceededError()\n        self._budget_left -= 1\n        score = 0.55 + 0.15 * p['time'] - 0.01 * (particle_id % 5)\n        uncertainty = max(0.0, 0.35 - 0.2 * p['time'])\n        rid = self._next_preview\n        self._next_preview += 1\n        rec = PreviewRecord(\n            id=rid,\n            particle_id=particle_id,\n            time=p['time'],\n            score=score,\n            score_dict={'score': score},\n            uncertainty=uncertainty,\n            drift=1.0 - p['time'],\n        )\n        self._previews[rid] = rec\n        p['last_preview_id'] = rid\n        p['nfe_used'] += 1\n        return rec\n\n    def backward(self, anchor_id, target_time, noise_policy='fresh_noise', num_children=1, mask=None, strength=1.0):\n        if num_children <= 0:\n            raise InvalidActionError('num_children')\n        parent = self._previews[anchor_id].particle_id\n        self._particles[parent]['num_children'] += num_children\n        ids = []\n        for _ in range(num_children):\n            pid = self._next_particle\n            self._next_particle += 1\n            self._particles[pid] = {\n                'id': pid,\n                'time': target_time,\n                'parent_id': parent,\n                'source_anchor_id': anchor_id,\n                'nfe_used': 0,\n                'status': 'completed' if target_time >= 1.0 else 'active',\n                'last_preview_id': None,\n                'num_children': 0,\n            }\n            ids.append(pid)\n        return ids\n\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            p = self._particles[pid]\n            if p['status'] == 'completed':\n                raise InvalidActionError('cannot prune completed')\n            p['status'] = 'pruned'\n\n    def answer(self, rule='best_preview_score'):\n        self._answered = True\n        previews = list(self._previews.values())\n        if rule == 'best_preview_score' and previews:\n            best = max(previews, key=lambda x: x.score)\n            return AnswerRecord(\n                particle_id=best.particle_id,\n                preview_id=best.id,\n                latent=(),\n                reward=best.score,\n                nfe_used=self.budget - self._budget_left,\n                rule=rule,\n                event_log=[],\n                score_dict=best.score_dict,\n            )\n        active = [p for p in self._particles.values() if p['status'] \"'!= '\"'pruned']\n        if not active:\n            return AnswerRecord(None, None, (), None, self.budget - self._budget_left, rule, [], {})\n        best = max(active, key=lambda x: (x['time'], -x['id']))\n        return AnswerRecord(\n            particle_id=best['id'],\n            preview_id=best['last_preview_id'],\n            latent=(),\n            reward=0.0,\n            nfe_used=self.budget - self._budget_left,\n            rule=rule,\n            event_log=[],\n            score_dict={},\n        )\n\n    def get_state(self):\n        particles = {\n            pid: ParticleSummary(**p)\n            for pid, p in self._particles.items()\n        }\n        return ControllerState(\n            prompt='x',\n            budget_left=self._budget_left,\n            active_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'active'],\n            completed_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'completed'],\n            pruned_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'pruned'],\n            particles=particles,\n            previews=dict(self._previews),\n            event_log=[],\n        )\n\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = FakeEnv(128)\n    ans = OptimalController().solve(env, beta)\n    print(beta, ans.rule, ans.nfe_used, ans.reward, len(env.get_state().previews), len(env.get_state().particles))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
