or('cannot prune completed')\n            p['status'] = 'pruned'\n\n    def answer(self, rule='best_preview_score'):\n        self._answered = True\n        previews = list(self._previews.values())\n        if rule == 'best_preview_score' and previews:\n            best = max(previews, key=lambda x: x.score)\n            return AnswerRecord(\n                particle_id=best.particle_id,\n                preview_id=best.id,\n                latent=(),\n                reward=best.score,\n                nfe_used=self.budget - self._budget_left,\n                rule=rule,\n                event_log=[],\n                score_dict=best.score_dict,\n            )\n        active = [p for p in self._particles.values() if p['status'] \"'!= '\"'pruned']\n        if not active:\n            return AnswerRecord(None, None, (), None, self.budget - self._budget_left, rule, [], {})\n        best = max(active, key=lambda x: (x['time'], -x['id']))\n        return AnswerRecord(\n            particle_id=best['id'],\n            preview_id=best['last_preview_id'],\n            latent=(),\n            reward=0.0,\n            nfe_used=self.budget - self._budget_left,\n            rule=rule,\n            event_log=[],\n            score_dict={},\n        )\n\n    def get_state(self):\n        particles = {\n            pid: ParticleSummary(**p)\n            for pid, p in self._particles.items()\n        }\n        return ControllerState(\n            prompt='x',\n            budget_left=self._budget_left,\n            active_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'active'],\n            completed_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'completed'],\n            pruned_particle_ids=[pid for pid, p in self._particles.items() if p['status'] == 'pruned'],\n            particles=particles,\n            previews=dict(self._previews),\n            event_log=[],\n        )\n\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = FakeEnv(128)\n    ans = OptimalController().solve(env, beta)\n    print(beta, ans.rule, ans.nfe_used, ans.reward, len(env.get_state().previews), len(env.get_state().particles))\nPY\"","aggregated_output":"/bin/bash: line 1: python: command not found\n","exit_code":127,"status":"failed"}}
