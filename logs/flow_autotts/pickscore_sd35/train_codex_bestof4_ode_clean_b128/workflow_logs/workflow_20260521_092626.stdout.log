{"type":"item.started","item":{"id":"item_31","type":"command_execution","command":"/bin/bash -lc \"python3 - <<'PY'\nfrom types import SimpleNamespace\nfrom flow_autotts.controllers.optimal import OptimalController\n\nclass DummyPreview(SimpleNamespace):\n    pass\n\nclass DummyParticle(SimpleNamespace):\n    pass\n\nclass DummyState(SimpleNamespace):\n    pass\n\nclass DummyEnv:\n    def __init__(self, budget=64):\n        self.time_grid = tuple(i / 10 for i in range(11))\n        self.budget = budget\n        self.budget_left = budget\n        self._answered = False\n        self._next_pid = 0\n        self._next_aid = 0\n        self._particles = {}\n        self._previews = {}\n    def spawn(self, n):\n        ids = []\n        for _ in range(n):\n            pid = self._next_pid\n            self._next_pid += 1\n            self._particles[pid] = DummyParticle(id=pid, time=0.0, status='active', last_preview_id=None)\n            ids.append(pid)\n        return ids\n    def forward(self, particle_id, target_time, solver='euler', cfg=None):\n        p = self._particles[particle_id]\n        p.time = float(target_time)\n        if p.time >= 1.0:\n            p.status = 'completed'\n        self.budget_left -= 1 if solver == 'euler' else 2\n        return p\n    def preview(self, particle_id, mode='clean_anchor', scorer='default'):\n        p = self._particles[particle_id]\n        aid = self._next_aid\n        self._next_aid += 1\n        score = 0.5 + 0.01 * particle_id + 0.001 * aid\n        prev = DummyPreview(id=aid, particle_id=particle_id, time=p.time, score=score, score_dict={'pickscore': score}, uncertainty=max(0.0, 1.0-p.time), drift=0.1)\n        self._previews[aid] = prev\n        p.last_preview_id = aid\n        self.budget_left -= 1\n        return prev\n    def backward(self, anchor_id, target_time, noise_policy='fresh_noise', num_children=1, mask=None, strength=1.0):\n        child_ids=[]\n        for _ in range(num_children):\n            pid=self._next_pid; self._next_pid += 1\n            self._particles[pid] = DummyParticle(id=pid, time=float(target_time), status='active' if target_time < 1.0 else 'completed', last_preview_id=None)\n            child_ids.append(pid)\n        return child_ids\n    def prune(self, particle_ids):\n        for pid in particle_ids:\n            self._particles[pid].status='pruned'\n    def answer(self, rule='best_preview_score'):\n        return SimpleNamespace(rule=rule, nfe_used=self.budget-self.budget_left)\n    def get_state(self):\n        return DummyState(\n            particles={pid: p for pid,p in self._particles.items()},\n            previews={aid: p for aid,p in self._previews.items()},\n            budget_left=self.budget_left,\n        )\n\nctrl = OptimalController()\nfor beta in [0.0, 0.25, 0.5, 0.75, 1.0]:\n    env = DummyEnv()\n    ans = ctrl.solve(env, beta)\n    print(beta, ans.rule, ans.nfe_used, env.budget_left)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
