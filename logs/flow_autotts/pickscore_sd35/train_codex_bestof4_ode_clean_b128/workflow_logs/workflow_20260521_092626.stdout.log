7\t                return\n   198\t            num_children = int(schedule[\"branch_children\"])\n   199\t            if index == 0 and beta >= 0.8 and self._score_gap(ranked) <= float(schedule[\"score_gap\"]):\n   200\t                num_children += 1\n   201\t            if index > 0 and beta < 0.75:\n   202\t                num_children = 1\n   203\t            try:\n   204\t                child_ids = env.backward(\n   205\t                    anchor.id,\n   206\t                    target_time=target_time,\n   207\t                    noise_policy=str(schedule[\"noise_policy\"]),\n   208\t                    num_children=num_children,\n   209\t                    strength=float(schedule[\"noise_strength\"]),\n   210\t                )\n   211\t            except (BudgetExceededError, InvalidActionError):\n   212\t                return\n   213\t\n   214\t            self._prune_if_clear_loser(env, ranked, anchor)\n   215\t            for child_id in child_ids:\n   216\t                if env.budget_left <= 0:\n   217\t                    return\n   218\t                try:\n   219\t                    self._advance_particle(env, child_id, finish_time, allow_stop=True)\n   220\t                    if env.budget_left > 0:\n   221\t                        env.preview(child_id, mode=\"clean_anchor\", scorer=\"default\")\n   222\t                except (BudgetExceededError, InvalidActionError):\n   223\t                    return\n   224\t\n   225\t        if beta >= 0.8 and env.budget_left > 0:\n   226\t            self._top_off(env, ranked, schedule, initial_budget)\n   227\t\n   228\t    def _choose_branch_anchors(\n   229\t        self,\n   230\t        ranked: list[PreviewRecord],\n   231\t        branch_count: int,\n   232\t        schedule: dict[str, float | int],\n   233\t        beta: float,\n   234\t    ) -> list[PreviewRecord]:\n   235\t        chosen: list[PreviewRecord] = []\n   236\t        gap = self._score_gap(ranked)\n   237\t        top_uncertainty = float(ranked[0].uncertainty or 0.0)\n   238\t        if gap <= float(schedule[\"score_gap\"]) or top_uncertainty >= float(schedule[\"uncertainty\"]):\n   239\t            chosen.append(ranked[0])\n   240\t        for preview in ranked[1:]:\n   241\t            if len(chosen) >= branch_count:\n   242\t                break\n   243\t            if beta < 0.5 and preview.time < ranked[0].time:\n   244\t                continue\n   245\t            chosen.append(preview)\n   246\t        if not chosen:\n   247\t            chosen.append(ranked[0])\n   248\t        return chosen[:branch_count]\n   249\t\n   250\t    def _prune_if_clear_loser(self, env: FlowTTSEnv, ranked: list[PreviewRecord], anchor: PreviewRecord) -> None:\n   251\t        if len(ranked) < 2:\n   252\t            return\n   253\t        gap = self._score_gap(ranked)\n   254\t        if gap > 0.03 and float(anchor.score or 0.0) < float(ranked[0].score or 0.0):\n   255\t            try:\n   256\t                env.prune([anchor.particle_id])\n   257\t            except (BudgetExceededError, InvalidActionError):\n   258\t                return\n   259\t\n   260\t    def _top_off(\n   261\t        self,\n   262\t        env: FlowTTSEnv,\n   263\t        ranked: list[PreviewRecord],\n   264\t        schedule: dict[str, float | int],\n   265\t        initial_budget: int,\n   266\t    ) -> None:\n   267\t        if not ranked or env.budget_left <= 0:\n   268\t            return\n   269\t        target_time = float(schedule[\"finish_time\"])\n   270\t        anchor = ranked[0]\n   271\t        passes = int(schedule[\"topoff_passes\"])\n   272\t        for round_index in range(passes):\n   273\t            if env.budget_left <= 0:\n   274\t                return\n   275\t            try:\n   276\t                child_ids = env.backward(\n   277\t                    anchor.id,\n   278\t                    target_time=target_time,\n   279\t                    noise_policy=\"mixed_noise\" if round_index > 0 else str(schedule[\"noise_policy\"]),\n   280\t                    num_children=1,\n   281\t                    strength=max(0.25, float(schedule[\"noise_strength\"]) * (0.90 if round_index == 0 else 0.75)),\n   282\t                )\n   283\t            except (BudgetExceededError, InvalidActionError):\n   284\t                return\n   285\t            for child_id in child_ids:\n   286\t                if env.budget_left <= 0:\n   287\t                    return\n   288\t                try:\n   289\t                    self._advance_particle(env, child_id, target_time)\n   290\t                    env.preview(child_id, mode=\"clean_anchor\", scorer=\"default\")\n   291\t                except (BudgetExceededError, InvalidActionError):\n   292\t                    return\n   293\t\n   294\t    def _late_confirmation(\n   295\t        self,\n   296\t        env: FlowTTSEnv,\n   297\t        ranked: list[PreviewRecord],\n   298\t        schedule: dict[str, float | int],\n   299\t        initial_budget: int,\n   300\t        beta: float,\n   301\t    ) -> None:\n   302\t        if not ranked or env.budget_left <= 0:\n   303\t            return\n   304\t        gap = self._score_gap(ranked)\n   305\t        if gap > float(schedule[\"score_gap\"]) and float(ranked[0].uncertainty or 0.0) < float(schedule[\"uncertainty\"]):\n   306\t            return\n   307\t        passes = 1 + int(beta >= 0.85)\n   308\t        confirm_time = float(schedule[\"finish_time\"]) if beta >= 0.85 else float(schedule[\"branch_time\"])\n   309\t        for round_index in range(passes):\n   310\t            if env.budget_left <= 0 or self._spent(env, initial_budget) >= initial_budget:\n   311\t                return\n   312\t            anchor = ranked[min(round_index, len(ranked) - 1)]\n   313\t            try:\n   314\t                child_ids = env.backward(\n   315\t                    anchor.id,\n   316\t                    target_time=confirm_time,\n   317\t                    noise