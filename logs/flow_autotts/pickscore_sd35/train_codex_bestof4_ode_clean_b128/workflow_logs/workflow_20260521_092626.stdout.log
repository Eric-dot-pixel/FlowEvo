e().particles[particle_id]\n\n    def preview(self, particle_id, mode='clean_anchor', scorer='default'):\n        particle = self._particles[particle_id]\n        if particle['status'] == 'pruned':\n            raise InvalidActionError('pruned preview')\n        if self._budget_left < 1:\n            raise BudgetExceededError()\n        self._budget_left -= 1\n        score = 0.55 + 0.14 * particle['time'] - 0.01 * (particle_id % 5)\n        uncertainty = max(0.0, 0.30 - 0.18 * particle['time'])\n        preview_id = self._next_preview\n        self._next_preview += 1\n        record = PreviewRecord(\n            id=preview_id,\n            particle_id=particle_id,\n            time=particle['time'],\n            score=score,\n            score_dict={'score': score},\n            uncertainty=uncertainty,\n            drift=1.0 - particle['time'],\n        )\n        self._previews[preview_id] = record\n        particle['last_preview_id'] = preview_id\n        particle['nfe_used'] += 1\n        return record\n\n    def backward(self, anchor_id, target_time, noise_policy='fresh_noise', num_children=1, mask=None, strength=1.0):\n        if num_children <= 0:\n            raise InvalidActionError('num_children <= 0')\n        if anchor_id not in self._previews:\n            raise InvalidActionError('unknown anchor')\n        parent_id = self._previews[anchor_id].particle_id\n        self._particles[parent_id]['num_children'] += num_children\n        ids = []\n        for _ in range(num_children):\n            pid = self._next_particle\n            self._next_particle += 1\n            self._particles[pid] = {\n                'id': pid,\n                'time': target_time,\n                'parent_id': parent_id,\n                'source_anchor_id': anchor_id,\n                'nfe_used': 0,\n                'status': 'completed' if target_time >= 1.0 else 'active',\n                'last_preview_id': None,\n                'num_children': 0,\n            }\n          