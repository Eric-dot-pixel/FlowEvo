{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/bin/bash -lc \"nl -ba flow_autotts/controllers/optimal.py | sed -n '1,240p'\"","aggregated_output":"     1\t\"\"\"Candidate controller for SD3.5 PickScore discovery.\"\"\"\n     2\t\n     3\tfrom __future__ import annotations\n     4\t\n     5\tfrom flow_autotts.core.env import FlowTTSEnv\n     6\tfrom flow_autotts.core.errors import BudgetExceededError, InvalidActionError\n     7\tfrom flow_autotts.core.state import AnswerRecord, PreviewRecord\n     8\t\n     9\t\n    10\tclass OptimalController:\n    11\t    \"\"\"Completed-anchor best-of-N with beta-scaled late refinement.\"\"\"\n    12\t\n    13\t    def solve(self, env: FlowTTSEnv, beta: float) -> AnswerRecord:\n    14\t        beta = min(max(float(beta), 0.0), 1.0)\n    15\t        initial_budget = max(0, int(env.budget_left))\n    16\t\n    17\t        root_id = env.spawn(1)[0]\n    18\t        try:\n    19\t            self._finish(env, root_id)\n    20\t        except BudgetExceededError:\n    21\t            return env.answer(rule=\"latest_active\")\n    22\t\n    23\t        if beta <= 0.0 or env.budget_left <= 0:\n    24\t            return env.answer(rule=\"latest_active\")\n    25\t\n    26\t        target_nfe = self._target_nfe(initial_budget, beta, spent=initial_budget - env.budget_left)\n    27\t        self._preview(env, root_id, target_nfe, initial_budget)\n    28\t\n    29\t        step_count = max(1, len(env.time_grid) - 1)\n    30\t        full_candidate_cost = step_count + 1\n    31\t        full_candidates = max(1, min(5, 1 + int(4 * beta), target_nfe // full_candidate_cost))\n    32\t        extra_roots = max(0, full_candidates - 1)\n    33\t        if extra_roots > 0:\n    34\t            for particle_id in env.spawn(extra_roots):\n    35\t                if self._spent(env, initial_budget) + full_candidate_cost > target_nfe:\n    36\t                    break\n    37\t                try:\n    38\t                    self._finish(env, particle_id)\n    39\t                    self._preview(env, particle_id, target_nfe, initial_budget)\n    40\t                except (BudgetExceededError, InvalidActionError):\n    41\t                    break\n    42\t\n    43\t        self._refine_from_best_previews(env, beta, target_nfe, initial_budget)\n    44\t        return env.answer(rule=\"best_preview_score\")\n    45\t\n    46\t    def _target_nfe(self, initial_budget: int, beta: float, spent: int) -> int:\n    47\t        if initial_budget <= spent:\n    48\t            return spent\n    49\t        extra = int((initial_budget - spent) * beta)\n    50\t        if beta > 0.0:\n    51\t            extra = max(1, extra)\n    52\t        return min(initial_budget, spent + extra)\n    53\t\n    54\t    def _finish(self, env: FlowTTSEnv, particle_id: int) -> None:\n    55\t        state = env.get_state()\n    56\t        current_time = state.particles[particle_id].time\n    57\t        for target_time in env.time_grid:\n    58\t            if target_time > current_time:\n    59\t                env.forward(particle_id, target_time=target_time, solver=\"euler\")\n    60\t                current_time = target_time\n    61\t\n    62\t    def _preview(\n    63\t        self,\n    64\t        env: FlowTTSEnv,\n    65\t        particle_id: int,\n    66\t        target_nfe: int,\n    67\t        initial_budget: int,\n    68\t    ) -> None:\n    69\t        if self._spent(env, initial_budget) + 1 <= target_nfe and env.budget_left > 0:\n    70\t            env.preview(particle_id, mode=\"clean_anchor\", scorer=\"default\")\n    71\t\n    72\t    def _refine_from_best_previews(\n    73\t        self,\n    74\t        env: FlowTTSEnv,\n    75\t        beta: float,\n    76\t        target_nfe: int,\n    77\t        initial_budget: int,\n    78\t    ) -> None:\n    79\t        target_time = self._backward_time(beta)\n    80\t        noise_policy = \"mixed_noise\" if beta >= 0.6 else \"fresh_noise\"\n    81\t        strength = 0.35 if noise_policy == \"mixed_noise\" else 1.0\n    82\t        max_children = max(0, int(1 + 4 * beta))\n    83\t\n    84\t        children_made = 0\n    85\t        while children_made < max_children:\n    86\t            previews = self._ranked_previews(env)\n    87\t            if not previews:\n    88\t                return\n    89\t            anchor = previews[children_made % len(previews)]\n    90\t            child_cost = self._child_finish_preview_cost(env, target_time)\n    91\t            if self._spent(env, initial_budget) + child_cost > target_nfe:\n    92\t                return\n    93\t            try:\n    94\t                child_id = env.backward(\n    95\t                    anchor.id,\n    96\t                    target_time=target_time,\n    97\t                    noise_policy=noise_policy,\n    98\t                    num_children=1,\n    99\t                    strength=strength,\n   100\t                )[0]\n   101\t                self._finish(env, child_id)\n   102\t                self._preview(env, child_id, target_nfe, initial_budget)\n   103\t            except (BudgetExceededError, InvalidActionError):\n   104\t                return\n   105\t            children_made += 1\n   106\t\n   107\t    def _ranked_previews(self, env: FlowTTSEnv) -> list[PreviewRecord]:\n   108\t        state = env.get_state()\n   109\t        previews = [\n   110\t            preview\n   111\t            for preview in state.previews.values()\n   112\t            if preview.score is not None\n   113\t            and preview.particle_id in state.particles\n   114\t            and state.particles[preview.particle_id].status != \"pruned\"\n   115\t        ]\n   116\t        return sorted(\n   117\t            previews,\n   118\t            key=lambda preview: (\n   119\t                float(preview.score),\n   120\t                -float(preview.uncertainty or 0.0),\n   121\t                float(preview.time),\n   122\t            ),\n   123\t            reverse=True,\n   124\t        )\n   125\t\n   126\t    def _child_finish_preview_cost(self, env: FlowTTSEnv, target_time: float) -> int:\n   127\t        forward_steps = sum(1 for time in env.time_grid if time > target_time)\n   128\t        return max(1, forward_steps) + 1\n   129\t\n   130\t    def _backward_time(self, beta: float) -> float:\n   131\t        if beta >= 0.8:\n   132\t            return 0.65\n   133\t        if beta >= 0.5:\n   134\t            return 0.75\n   135\t        return 0.85\n   136\t\n   137\t    def _spent(self, env: FlowTTSEnv, initial_budget: int) -> int:\n   138\t        return max(0, int(initial_budget - env.budget_left))\n   139\t\n","exit_code":0,"status":"completed"}}
